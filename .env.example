# Telegram API credentials
# Get from https://my.telegram.org/apps
API_ID=your_api_id
API_HASH=your_api_hash

# Session name (file will be created as {SESSION_NAME}.session)
TELEGRAM_SESSION_NAME=my_session

# Your Telegram user_id — only this user can trigger the AI agent via watcher
# Get your user_id by messaging @userinfobot in Telegram
TELEGRAM_OWNER_ID=your_user_id
